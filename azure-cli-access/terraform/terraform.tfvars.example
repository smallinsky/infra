location               = "westeurope"
prefix                 = "teleport-azure"
vm_size                = "Standard_B2s"
admin_username         = "azureuser"
# admin_ssh_public_key_path = "../id_rsa_azure.pub"  # default; generated by `make ssh-key`
teleport_proxy_address = "igs-aws-dev.cloud.gravitational.io:443"
teleport_app_name      = "azure-cli"
